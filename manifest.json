{
  "manifest_version": 3,
  "name": "Chinese Hover Translator",
  "version": "1.0",
  "description": "Translate English words on hover.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "toggle-floating-window": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open/close floatingWindow"
    },
    "translate": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Translate the hovered word"
    },
    "change-type": {
      "suggested_key": {
        "default": "Ctrl+Y",
        "mac": "Command+Y"
      },
      "description": "Exchange language"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["md5.js", "content.js"],
      "css": ["tooltip.css"]
    }
  ]
}